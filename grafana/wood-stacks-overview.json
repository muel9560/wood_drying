      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 4,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none"
          },
          "unit": "percent",
          "displayName": "${__field.labels.thickness} \u00b7 b${__field.labels.board} \u00b7 ${__field.labels.spot} \u00b7 ${__field.labels.depth}",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "min",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${datasource}"
          },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"woodstack\" and r.kind == \"wood\" and r._field == \"mc\" and r.thickness =~ /${thickness:regex}/ and r.stack =~ /${stack:regex}/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"thickness\", \"board\", \"spot\", \"depth\"])\n  |> group(columns: [\"thickness\", \"board\", \"spot\", \"depth\"])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Board list \u2014 latest MC + trend",
      "description": "One row per probe. Sparkline = recent MC history, number = latest.",
      "datasource": {
        "type": "influxdb",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 10
