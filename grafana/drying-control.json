{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.6.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Drying-rate guardrails",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Drying rate (%/week)",
      "description": "MC loss per week (daily-median slope \u00d77). Keep under ~1%/week while MC>20% to limit checking/cracking \u2014 red line is the guardrail.",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "percent",
          "displayName": "${__field.labels.thickness} \u00b7 b${__field.labels.board} \u00b7 ${__field.labels.spot} \u00b7 ${__field.labels.depth}",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1.0,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "min",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"woodstack\" and r.kind == \"wood\" and r._field == \"mc\" and r.thickness =~ /${thickness:regex}/ and r.stack =~ /${stack:regex}/)\n  |> aggregateWindow(every: 1d, fn: median, createEmpty: false)\n  |> derivative(unit: 7d, nonNegative: false)\n  |> map(fn: (r) => ({r with _value: r._value * -1.0}))\n  |> keep(columns: [\"_time\", \"_value\", \"thickness\", \"board\", \"spot\", \"depth\"])\n  |> group(columns: [\"thickness\", \"board\", \"spot\", \"depth\"])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Shell\u2212core differential (shallow \u2212 deep)",
      "description": "Shallow minus deep per board. Growing gap = shell drying ahead of core (case-hardening risk). Tighten the cover past ~5% (10/4+), ~4% (13/4).",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "percent",
          "displayName": "${__field.labels.thickness} \u00b7 b${__field.labels.board} \u00b7 ${__field.labels.spot}",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 4.0,
                "color": "orange"
              },
              {
                "value": 5.0,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "min",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"woodstack\" and r.kind == \"wood\" and r._field == \"mc\" and r.thickness =~ /${thickness:regex}/ and r.stack =~ /${stack:regex}/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> pivot(rowKey: [\"_time\", \"thickness\", \"board\", \"spot\"], columnKey: [\"depth\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.shallow and exists r.deep)\n  |> map(fn: (r) => ({_time: r._time, thickness: r.thickness, board: r.board, spot: r.spot, _value: r.shallow - r.deep}))\n  |> group(columns: [\"thickness\", \"board\", \"spot\"])",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15m",
  "schemaVersion": 39,
  "tags": [
    "woodstack",
    "drying"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "bucket",
        "options": [],
        "query": {
          "query": "buckets() |> keep(columns: [\"name\"]) |> rename(columns: {name: \"_value\"}) |> sort()"
        },
        "refresh": 1,
        "regex": "",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "label": "Bucket"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "stack",
        "options": [],
        "query": {
          "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"stack\", predicate: (r) => r._measurement == \"woodstack\", start: -90d)"
        },
        "refresh": 1,
        "regex": "",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "label": "Stack",
        "allValue": ".*"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "thickness",
        "options": [],
        "query": {
          "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"thickness\", predicate: (r) => r._measurement == \"woodstack\", start: -90d)"
        },
        "refresh": 1,
        "regex": "",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "label": "Thickness",
        "allValue": ".*"
      }
    ]
  },
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Wood Stacks \u2014 Drying Control",
  "uid": "woodstack-drying-control",
  "version": 1,
  "weekStart": ""
}